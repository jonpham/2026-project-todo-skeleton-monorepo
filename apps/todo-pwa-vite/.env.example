# Cloudflare API credentials
# DO NOT commit the .env file - it's in .gitignore
#
# Get these from https://dash.cloudflare.com/profile/api-tokens:
# 1. API Token: Create a token with Pages and Account permissions
# 2. Account ID: Found in the sidebar or account overview

CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id-here
