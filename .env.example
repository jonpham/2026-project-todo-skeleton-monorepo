# ============================================================
# Monorepo Infrastructure — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.
#
#   cp .env.example .env
#
# Required for: infra/ (monorepo deploy) and apps/todo-pwa/infra/ (standalone deploy)
# ============================================================

# Cloudflare API token with the following permissions:
#   Account > Cloudflare Pages > Edit
#   Account > Account Settings > Read
#   Zone > Zone > Read          (for witty-m.com)
#   Zone > DNS > Edit           (for witty-m.com)
# Create at: Cloudflare dashboard → My Profile → API Tokens
CLOUDFLARE_API_TOKEN=

# Cloudflare Account ID
# Found at: Cloudflare dashboard → Workers & Pages → right sidebar
# Or from the dashboard URL: dash.cloudflare.com/<account-id>/...
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Zone ID for witty-m.com
# Found at: Cloudflare dashboard → Websites → witty-m.com → right sidebar
# Used to bind custom domains via Pulumi
CLOUDFLARE_ZONE_ID=

# Pulumi stack name (used by infra/ orchestrator only)
# Use "prod" for production, or any name for a personal/preview stack
PULUMI_STACK=prod

# Optional: Turborepo remote cache (speeds up CI and local builds)
# TURBO_TOKEN=
# TURBO_TEAM=
