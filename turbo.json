{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {},
    "lint": {},
    "format": {},
    "test:e2e": {
      "dependsOn": ["^build"]
    }
  }
}
